# LLM 配置模板。
# 用法:复制本文件为 .env,填入真实值。.env 已在 .gitignore,不会被提交。

# 选厂商:claude 或 openai。换厂商只改这一项(+ 对应的 key),代码不用动。
PROVIDER=openai

# Claude(provider=claude 时必填)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# OpenAI / ChatGPT(provider=openai 时必填)
OPENAI_API_KEY=sk-xxxxxxxx

# 可选:覆盖默认模型。留空则用各 provider 的默认:
#   claude → claude-opus-4-8 ; openai → gpt-5.4-mini(便宜档,适合开发测试)
MODEL=gpt-5.4-mini

# 可选:其它覆盖
MAX_TOKENS=1024
# 通用采样温度;注意 Opus 4.8 / GPT-5 系列实际不下发此参数(见各 provider 实现)
TEMPERATURE=1.0
# CLI 默认是否流式输出(true/false)
STREAM=true
